--- !u!114 &87807346
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 87807344}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7687ab9d6e041412d9c974c9a140a800, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SceneTransition
  description: "Drop-in scene transition.\n\u2022 Destination: which scene + spawn
    anchor (ScriptableObject).\n\u2022 Effects: visual/audio effects that play during
    the load. Multiple allowed,\n  but each must use a different TransitionChannel
    (Screen/Audio/Camera/Time).\n\u2022 Add an InteractableTransitionTrigger or VolumeTransitionTrigger
    on the same\n  GameObject, or call Trigger(initiator) from script, to fire the
    transition.\n\u2022 Effects play during load. When the load finishes, the 'in'
    phase of each\n  effect runs and the transition completes.\n\u2022 Spacebar skips
    effects (skip is ignored until the load completes)."
  destination: {fileID: 11400000, guid: a3be0cad283b242df884f030a868aff9, type: 2}
  effects:
  - {fileID: 11400000, guid: 534ff89ac36fd4c5f9d62b58ea6af62d, type: 2}
