  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcDialogInteraction
  dialogMode: 0
  dialogLines:
  - I saw fresh tracks past the ridge.
  - There is salvage under the black rock, but the robots patrol there.
  - Bring a scanner if you head east.
  predefinedRandomPool:
  - That signal was close.
  - No, not this vein.
  - One more sample.
  - there is a defualt 3 seconds between sentences for the predefined pool
